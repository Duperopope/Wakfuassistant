# Python
__pycache__/
*.pyc
*.pyo

# Environnement virtuel
.venv/

# === LOGS BRUTS — jamais versionnes ===
logs/*
!logs/realtime/

# === REALTIME — uniquement snapshots structures ===
logs/realtime/*
