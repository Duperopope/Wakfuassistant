# Path to your Wakfu log file (override platform default)
# Windows example:
# WAKFU_LOG_PATH=C:\Users\YourName\AppData\Roaming\zaap\gamesLogs\wakfu\logs\wakfu.log
# Linux/macOS example:
# WAKFU_LOG_PATH=/home/yourname/.config/zaap/gamesLogs/wakfu/logs/wakfu.log

# Web server port (default: 5000)
# WEB_PORT=5000

# Parse existing log on startup (1=yes, 0=no, default: 1)
# PARSE_EXISTING_LOG=1

# SSE refresh interval in seconds (default: 2)
# REFRESH_INTERVAL=2
