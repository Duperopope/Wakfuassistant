{"ts_local": "2026-03-15 22:16:41.412", "ts_client": "22:16:41.412", "ntp_offset_ms": 76.136, "source_file": "wakfu_chat.log.1", "type": "chat", "data": {"channel": "Guilde", "author": "Azamateria", "message": "Si le jeux était si mort le coup des serveurs serait trop important pour garder le jeu ouvert aussi donc ... je crois que ces une impression faussé par l'expérience de jeu"}}
{"ts_local": "2026-03-15 22:16:52.073", "ts_client": "22:16:52.073", "ntp_offset_ms": 76.136, "source_file": "wakfu_chat.log.1", "type": "chat", "data": {"channel": "Recrutement (FR)", "author": "Oroza", "message": "Tu cherches une guilde active, conviviale, avec des sorties régulières, de nombreux bonus et un HM ? [Desperados] recrute !! Intéressé(e) ? MP-moi"}}
{"ts_local": "2026-03-15 22:16:57.733", "ts_client": "22:16:57.733", "ntp_offset_ms": 76.136, "source_file": "wakfu_chat.log.1", "type": "chat", "data": {"channel": "Commerce", "author": "Eh Pas De Pierre", "message": "WTS Pierre d'aventure 6m5, Bottes de Koko brulure II et Dernier instant 3m, Maniement : Bouclier 2m8 Sang de la Déchirure 2m3"}}
