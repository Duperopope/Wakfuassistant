{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/packages/api/schema.json",
  "productName": "Wakfu Overlay v2",
  "version": "4.0.6",
  "identifier": "com.wakfu-overlay.v2",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "toolbar",
        "title": "Wakfu Overlay - Toolbar",
        "width": 420,
        "height": 28,
        "minWidth": 200,
        "minHeight": 28,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "navbar",
        "title": "Wakfu Overlay - Navbar",
        "width": 420,
        "height": 72,
        "minWidth": 200,
        "minHeight": 72,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://wakfu.cdn.ankama.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "French"],
        "displayLanguageSelector": true
      }
    }
  }
}